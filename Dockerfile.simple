FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package.json ./
COPY tsconfig.json ./
COPY prisma ./prisma

# Install dependencies
RUN npm install

# Copy source
COPY src ./src
COPY examples ./examples

# Generate Prisma client
RUN npx prisma generate

# Create data directory
RUN mkdir -p /app/data

EXPOSE 3000

# Start with tsx (no build needed)
CMD ["npx", "tsx", "src/index.ts"]
